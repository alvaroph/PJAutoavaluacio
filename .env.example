# Copia aquest fitxer a .env i omple els valors abans d'executar docker compose up

# OAuth de Google (crea les credencials a https://console.cloud.google.com/apis/credentials)
# Tipus: ID de client OAuth per a aplicació web.
# Orígens JavaScript autoritzats: http://localhost:5173
GOOGLE_CLIENT_ID=
GOOGLE_ALLOWED_DOMAIN=inspedralbes.cat

# Secret per signar els JWT propis de l'aplicació (genera'n un de llarg i aleatori)
JWT_SECRET=

# URLs de l'aplicació
APP_URL=http://localhost:5173

# Base de dades
MYSQL_ROOT_PASSWORD=supersecret
MYSQL_DATABASE=autoavaluacio

# Professors inicials (separats per comes). Es creen/actualitzen en arrencar el backend.
ADMIN_EMAILS=aperezh@inspedralbes.cat
TEACHER_EMAILS=
