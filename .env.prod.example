# Còpia aquest fitxer a .env.prod i omple els valors reals
# Després: docker compose -f docker-compose.prod.yml --env-file .env.prod up -d --build

# Base de dades MySQL
MYSQL_ROOT_PASSWORD=canvia_aquesta_contrasenya
MYSQL_DATABASE=autoavaluacio

# Google OAuth (obtenir a console.cloud.google.com)
GOOGLE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_ALLOWED_DOMAIN=inspedralbes.cat

# Seguretat JWT (genera un secret llarg i aleatori)
JWT_SECRET=canvia_per_un_secret_llarg_i_aleatori

# URL pública de l'aplicació (sense barra final)
APP_URL=https://projectes.inspedralbes.cat

# Emails d'administradors (separats per comes)
ADMIN_EMAILS=admin@inspedralbes.cat

# Emails de professors inicials (separats per comes, opcional)
TEACHER_EMAILS=
